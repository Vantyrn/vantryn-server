# ============================================================================
# Vantryn Backend (vantryn-server) — environment template
# Copy to .env and fill in. NEVER commit the real .env. See SETUP_CREDENTIALS.md.
# ============================================================================

# ── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
RELEASE_VERSION=pilot-0.1.0
DEV_BYPASS=off                 # gate demo footguns (test OTP, fake payments); off in pilot

# ── Database (Neon Postgres — ONE canonical schema) ──────────────────────────
DATABASE_URL=postgresql://USER:PASS@HOST-pooler.../neondb?sslmode=require
DIRECT_URL=postgresql://USER:PASS@HOST.../neondb?sslmode=require   # optional, for migrations

# ── Backend secrets (generate: openssl rand -hex 32) ─────────────────────────
JWT_SECRET=
ADMIN_SECRET=                  # MUST match the Admin app; routes are OPEN if unset
ADMIN_SEED_PASSWORD=

# ── Firebase (server token verification + FCM) ───────────────────────────────
# Either the whole service-account JSON in one var…
FIREBASE_SERVICE_ACCOUNT=
# …or the split form:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Redis (Upstash / Railway) — BullMQ SLA timers ────────────────────────────
REDIS_URL=rediss://default:PASS@HOST:PORT
REDIS_TLS=true

# ── Observability (free/OSS: GlitchTip + Grafana Loki) ───────────────────────
SENTRY_DSN=                    # GlitchTip DSN
LOKI_URL=
LOKI_USER=
LOKI_API_KEY=

# ── Email (Admin password reset / transactional — Brevo/Resend) ──────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Vantryn <noreply@yourdomain.com>
# RESEND_API_KEY=

# ── Cloudflare R2 (KYC docs + images) — Tier 2 ───────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── Razorpay (UPI, TEST mode) — Tier 2 ───────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
USE_SANDBOX_PAYMENTS=true

# ── Shadowfax 3PL (HL MARKETPLACE API) — Tier 2 ──────────────────────────────
# Two INDEPENDENT flags:
#   SFX_DELIVERY_MODE  simulate → built-in rider simulator, no Shadowfax calls (default; localhost-friendly, no tunnel)
#                      live     → real Shadowfax API; live rider location arrives ONLY via callbacks (needs a PUBLIC URL)
#   SFX_ENV            staging | production — selects base URL + token + client_code. Flip to prod by changing ONLY this.
SFX_DELIVERY_MODE=simulate
SFX_ENV=staging
SFX_STAGING_BASE_URL=https://hlbackend.staging.shadowfax.in
SFX_PROD_BASE_URL=
# API token WE send to CALL Shadowfax, as `Authorization: Token <token>`. Issued by Shadowfax.
SFX_STAGING_TOKEN=
SFX_PROD_TOKEN=
# Marketplace `client_code` sent in the order-create body. Staging: vantyrn_mkt. Prod: confirm with Shadowfax.
SFX_STAGING_CLIENT_CODE=vantyrn_mkt
SFX_PROD_CLIENT_CODE=
# Bearer token Shadowfax sends back to US in the Authorization header of its callbacks. WE choose this
# value and register it with Shadowfax. Not the same as SFX_*_TOKEN above. Real value lives in .env.
SFX_WEBHOOK_SECRET=
